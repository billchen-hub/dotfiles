#!/bin/bash
# claude-tmux: Quick launcher for Claude Code multi-project tmux sessions
# Usage:
#   claude-tmux                    - List all sessions or create default
#   claude-tmux <project-name>     - Attach to or create a named session
#   claude-tmux <project-name> <path> - Create session with specific path
#   claude-tmux kill <session>     - Kill a specific session
#   claude-tmux list               - List all sessions

set -e

# Load nvm
export NVM_DIR="/home/cyc/.nvm"
[ -s "/nvm.sh" ] && . "/nvm.sh"

PROJECT=
PROJECT_PATH=

# Colors
GREEN="\033[0;32m"
BLUE="\033[0;34m"
YELLOW="\033[1;33m"
NC="\033[0m"

if [ -z "" ] || [ "" = "list" ]; then
    echo -e "=== Active Claude Code Sessions ==="
    echo -e "==================================="
    if tmux list-sessions 2>/dev/null; then
        echo ""
        echo -e "Usage: claude-tmux <project-name> [path]"
        echo -e "  Attach: claude-tmux <existing-session-name>"
        echo -e "  New:    claude-tmux my-project ~/projects/my-project"
    else
        echo -e "No active sessions."
        echo -e "Create one: claude-tmux <project-name> <path>"
    fi
    exit 0
fi

if [ "" = "kill" ]; then
    SESSION=
    if [ -z "" ]; then
        echo "Usage: claude-tmux kill <session-name>"
        exit 1
    fi
    tmux kill-session -t "" 2>/dev/null && echo -e "Session '' killed." || echo "Session '' not found."
    exit 0
fi

# If session exists, attach to it
if tmux has-session -t "" 2>/dev/null; then
    echo -e "Attaching to session: "
    tmux attach -t ""
    exit 0
fi

# Create new session
if [ -z "" ]; then
    # Default: check ~/projects/<name> or use home
    if [ -d "/home/cyc/projects/" ]; then
        PROJECT_PATH="/home/cyc/projects/"
    else
        PROJECT_PATH="/home/cyc/projects"
        echo -e "Note: ~/projects/ not found, using ~/projects/"
    fi
fi

echo -e "Creating new session:  (path: )"
tmux new-session -d -s "" -c ""
tmux send-keys -t "" "cd  && claude --continue" Enter
tmux attach -t ""
